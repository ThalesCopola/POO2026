@model IEnumerable<academico.Models.Aluno>

@{
    ViewData["Title"] = "Listagem de Alunos";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create">Adicionar Aluno</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Telefone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cep)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nome)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Telefone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cep)
            </td>
            <td>
                @Html.ActionLink("Editar", "Edit", new {  id=item.AlunoId }) |
                @Html.ActionLink("Detalhes", "Details", new { id=item.AlunoId }) |
                @Html.ActionLink("Deletar", "Delete", new {  id=item.AlunoId})
            </td>
        </tr>
}
    </tbody>
</table>
